rules_version = '2';

// Règles de sécurité Firestore — EBOK Event.
// À coller dans : console Firebase > Firestore Database > Règles > Publier.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    // Admin = présence d'un document à son nom dans la collection `admins`
    // (ajouté manuellement via la console — non modifiable par l'app).
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Événements :
    // - lecture publique
    // - création réservée aux comptes connectés, qui doivent se déclarer
    //   propriétaires (userId == leur uid) ; seul l'admin peut publier
    //   directement en "approved", sinon c'est "pending"
    // - modification / suppression par le propriétaire ou l'admin
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.userId == request.auth.uid
                    && (request.resource.data.status == 'pending' || isAdmin());
      allow update, delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Compteurs de "curieux" : lecture publique, écriture ouverte
    // (l'app incrémente à chaque visite).
    match /views/{eventId} {
      allow read: if true;
      allow write: if true;
    }

    // Profils diffuseurs : lecture publique (nom, insta affichés sur les
    // événements) ; chacun n'écrit que son propre profil.
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Liste des admins : lisible par les connectés, modifiable uniquement
    // via la console Firebase (jamais depuis l'app).
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
